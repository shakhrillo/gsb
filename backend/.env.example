# Push Notification Configuration

# Expo Access Token (optional, for enhanced security)
# Get this from https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=

# Push Notification Settings
PUSH_NOTIFICATION_ENABLED=true
PUSH_RECEIPT_CHECK_INTERVAL=15  # minutes

# Example settings (add these to your existing .env file)
# EXPO_ACCESS_TOKEN=expo_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
